{
  "name": "designer-worklog",
  "private": true,
  "version": "0.30.20",
  "type": "module",
  "scripts": {
    "baml:generate": "baml-cli generate",
    "dev": "vite",
    "build": "npm run baml:generate && tsc -b && vite build",
    "lint": "eslint .",
    "agent:eval:check": "node agent-evals/run.mjs --validate-only",
    "agent:eval": "node agent-evals/run.mjs",
    "agent:eval:isolated": "node agent-evals/run-isolated.mjs",
    "browser:eval": "playwright test",
    "agent:quality:gate": "npm run build && npm run lint && npm run agent:eval:isolated && npm run browser:eval",
    "preview": "vite preview",
    "deploy:pages": "npm run build && npx wrangler pages deploy dist --project-name designer-worklog",
    "deploy:worker": "npm run build && npx wrangler deploy"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.59",
    "@boundaryml/baml": "^0.222.0",
    "@cloudflare/puppeteer": "^1.1.0",
    "@lobehub/icons-static-svg": "^1.93.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ag-psd": "^30.1.1",
    "agents": "^0.17.3",
    "ai": "^6.0.223",
    "docx-preview": "^0.3.7",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "4.10.38",
    "pptx-preview": "^1.0.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "overrides": {
    "echarts": "^6.1.0",
    "uuid": "^11.1.1"
  }
}
