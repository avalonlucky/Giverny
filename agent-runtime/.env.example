AGENT_MODEL_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional OpenAI fallback/provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AGENT_MODEL=gpt-4.1-mini

# Public Giverny Worker origin. Use workers.dev if the custom domain is blocked.
GIVERNY_API_BASE_URL=https://mayeai.com
GIVERNY_AGENT_TOOL_TOKEN=

# Optional protection for this runtime. Frontend/Worker should send x-agent-runtime-key.
AGENT_RUNTIME_KEY=
AGENT_RUNTIME_CORS_ORIGINS=http://localhost:5173,https://mayeai.com
